<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>CRUD User LocalStorage</title>

<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:Arial, sans-serif;
}

body{
    background:#f5f5f5;
    padding:20px;
}

.container{
    max-width:1000px;
    margin:auto;
}

.card{
    background:white;
    padding:20px;
    border-radius:10px;
    margin-bottom:20px;
    box-shadow:0 2px 10px rgba(0,0,0,.1);
}

h2{
    margin-bottom:15px;
}

.form-grid{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(200px,1fr));
    gap:10px;
}

input, select{
    width:100%;
    padding:10px;
}

button{
    padding:10px 15px;
    border:none;
    cursor:pointer;
    border-radius:5px;
}

.btn-primary{
    background:#2196F3;
    color:white;
}

.btn-warning{
    background:orange;
    color:white;
}

.btn-danger{
    background:red;
    color:white;
}

.btn-success{
    background:green;
    color:white;
}

.actions{
    margin-top:15px;
    display:flex;
    gap:10px;
    flex-wrap:wrap;
}

table{
    width:100%;
    border-collapse:collapse;
}

th,td{
    border:1px solid #ddd;
    padding:10px;
    text-align:left;
}

tr:hover{
    background:#eee;
    cursor:pointer;
}

.selected{
    background:#cce5ff !important;
}

.hidden{
    display:none;
}

@media(max-width:768px){
    table{
        display:block;
        overflow-x:auto;
    }
}
</style>
</head>
<body>

<div class="container">

<!-- LOGIN -->

<div id="loginPage" class="card">
<h2>Login</h2>

<div class="form-grid">
<input type="text" id="loginUser" placeholder="User">
<input type="password" id="loginPass" placeholder="Password">
</div>

<div class="actions">
<button class="btn-primary" onclick="login()">
Login
</button>
</div>
</div>

<!-- CRUD -->

<div id="crudPage" class="hidden">

<div class="card">
<h2>Manajemen User</h2>

<div class="form-grid">

<input type="text" id="id" placeholder="ID">

<input type="text" id="user" placeholder="User">

<input type="text" id="nama" placeholder="Nama">

<input type="password" id="sandi" placeholder="Sandi">

<select id="status">
<option value="Aktif">Aktif</option>
<option value="Nonaktif">Nonaktif</option>
</select>

</div>

<div class="actions">

<button class="btn-success" onclick="addData()">
Tambah
</button>

<button class="btn-warning" onclick="updateData()">
Update
</button>

<button class="btn-danger" onclick="deleteData()">
Hapus
</button>

<button class="btn-primary" onclick="clearForm()">
Reset
</button>

</div>

</div>

<div class="card">

<h2>Data User</h2>

<table id="dataTable"></table>

</div>

</div>

</div>

<script>

const STORAGE_KEY = "users";

const columns = [
"id",
"user",
"nama",
"sandi",
"status"
];

let selectedIndex = -1;

function getData(){
    return JSON.parse(
        localStorage.getItem(STORAGE_KEY)
    ) || [
        {
            id:"1",
            user:"admin",
            nama:"Administrator",
            sandi:"admin",
            status:"Aktif"
        }
    ];
}

function saveData(data){
    localStorage.setItem(
        STORAGE_KEY,
        JSON.stringify(data)
    );
}

function renderTable(){

    const data = getData();

    let html = "<thead><tr>";

    columns.forEach(col=>{
        html += `<th>${col.toUpperCase()}</th>`;
    });

    html += "</tr></thead><tbody>";

    data.forEach((row,index)=>{

        html += `
        <tr onclick="selectRow(${index})">

        ${columns.map(col=>
        `<td>${row[col]}</td>`
        ).join("")}

        </tr>
        `;

    });

    html += "</tbody>";

    document.getElementById("dataTable").innerHTML = html;
}

function selectRow(index){

    selectedIndex = index;

    const data = getData();

    const row = data[index];

    columns.forEach(col=>{
        document.getElementById(col).value =
        row[col];
    });

    document.querySelectorAll("tbody tr")
    .forEach(r=>r.classList.remove("selected"));

    document.querySelectorAll("tbody tr")[index]
    .classList.add("selected");
}

function getFormData(){

    let obj = {};

    columns.forEach(col=>{
        obj[col] =
        document.getElementById(col).value;
    });

    return obj;
}

function addData(){

    const data = getData();

    data.push(
        getFormData()
    );

    saveData(data);

    renderTable();

    clearForm();
}

function updateData(){

    if(selectedIndex < 0){
        alert("Pilih data terlebih dahulu");
        return;
    }

    const data = getData();

    data[selectedIndex] =
    getFormData();

    saveData(data);

    renderTable();
}

function deleteData(){

    if(selectedIndex < 0){
        alert("Pilih data terlebih dahulu");
        return;
    }

    const data = getData();

    data.splice(selectedIndex,1);

    saveData(data);

    renderTable();

    clearForm();
}

function clearForm(){

    columns.forEach(col=>{
        document.getElementById(col).value="";
    });

    document.getElementById("status").value="Aktif";

    selectedIndex = -1;
}

function login(){

    const username =
    document.getElementById("loginUser").value;

    const password =
    document.getElementById("loginPass").value;

    const data = getData();

    const user = data.find(
        x =>
        x.user === username &&
        x.sandi === password &&
        x.status === "Aktif"
    );

    if(user){

        document
        .getElementById("loginPage")
        .classList.add("hidden");

        document
        .getElementById("crudPage")
        .classList.remove("hidden");

        renderTable();

    }else{

        alert("Login gagal");

    }
}

saveData(getData());

</script>

</body>
</html>
